<%# 💡 外側のheaderは「透明(bg-transparent)」にし、ボーダーや影も外します %>
<header class="navbar navbar-expand-lg navbar-light bg-transparent p-0 mb-4">
  
  <%# 💡 この div を「白いカード」のように見せます。幅制限、白背景、影、角丸を設定 %>
  <div style="max-width: 1250px; margin: 20px auto 0 auto; width: 100%; background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06); padding: 0.75rem 1.5rem;" 
       class="d-flex align-items-center">
    
    <%# --- 以下、ロジックは変更ありません --- %>

    <%# 1. イベントアイコン %>
    <div class="me-3">
      <% if @current_event.persisted? %>
        <%= link_to edit_event_path(@current_event), title: "イベント詳細・編集", class: "d-block" do %>
          <% if @current_event.icon_image.attached? %>
            <%= image_tag @current_event.icon_image, style: "width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 2px solid #0d6efd;" %>
          <% else %>
            <div style="width: 45px; height: 45px; background: #f8f9fa; border-radius: 50%; border: 2px dashed #dee2e6; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">🗓</div>
          <% end %>
        <% end %>
      <% else %>
        <div style="width: 45px; height: 45px; background: #f8f9fa; border-radius: 50%; border: 2px dashed #dee2e6; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;" title="イベントを登録してください">🗓</div>
      <% end %>
    </div>

    <%# 2. イベント名ドロップダウン %>
    <div class="dropdown me-auto">
      <button class="btn btn-link dropdown-toggle text-dark text-decoration-none p-0" type="button" id="eventSelector" data-bs-toggle="dropdown" aria-expanded="false">
        <h2 class="h5 mb-0 d-inline-block font-weight-bold" style="font-weight: 800; color: #1a202c;">
          <%= @current_event.name %>
        </h2>
      </button>
      <ul class="dropdown-menu shadow border-0" aria-labelledby="eventSelector">
        <li class="dropdown-header">表示イベントを切り替え</li>
        <% Event.where.not(id: nil).order(start_date: :desc).each do |event| %>
          <li>
            <%= link_to event.name, url_for(event_id: event.id), class: "dropdown-item #{'active' if event.id == @current_event.id}" %>
          </li>
        <% end %>
        <li><hr class="dropdown-divider"></li>
        <li>
          <%= link_to "＋ 新規イベント作成", new_event_path, class: "dropdown-item text-success fw-bold" %>
        </li>
      </ul>
    </div>

    <%# 3. 駐車場などのステータス表示 %>
    <div class="d-flex align-items-center gap-3">
      <% if @current_event.persisted? && @current_event.parking_info.present? %>
        <span class="badge bg-light text-dark border p-2" style="font-size: 0.75rem;" title="<%= @current_event.parking_info %>">
          🅿️ 駐車場情報あり
        </span>
      <% end %>
      
      <%= link_to "店舗一覧", shops_path, class: "btn btn-outline-primary btn-sm fw-bold px-3" %>
      <%= link_to "レイアウト編集", layout_event_shops_path(@current_event), class: "btn btn-outline-secondary btn-sm fw-bold px-3" %>
    </div>
  </div>
</header>
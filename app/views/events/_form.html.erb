<%# app/views/events/_form.html.erb %>
<%= form_with(model: event, local: true, class: "container", style: "max-width: 800px; margin-top: 20px;") do |f| %>
  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="card-title mb-4">🗓 イベント情報の設定</h2>

      <div class="mb-4 text-center">
        <label class="form-label d-block">イベントアイコン（ロゴ等）</label>
        <% if event.icon_image.attached? %>
          <%= image_tag event.icon_image, style: "width: 100px; height: 100px; object-fit: cover; border-radius: 50%; border: 2px solid #ddd; margin-bottom: 10px;" %>
        <% end %>
        <%= f.file_field :icon_image, class: "form-control" %>
      </div>

      <div class="row g-3">
        <div class="col-12">
          <%= f.label :name, "イベント名", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", placeholder: "例：わんわんマルシェ vol.40" %>
        </div>

        <div class="col-md-6">
          <%= f.label :start_date, "開催開始日", class: "form-label" %>
          <%= f.date_field :start_date, class: "form-control" %>
        </div>
        <div class="col-md-6">
          <%= f.label :end_date, "開催終了日", class: "form-label" %>
          <%= f.date_field :end_date, class: "form-control" %>
        </div>

        <div class="col-12">
          <%= f.label :location, "開催会場名", class: "form-label" %>
          <%= f.text_field :location, class: "form-control", placeholder: "例：神戸メリケンパーク" %>
        </div>

        <div class="col-12">
          <%= f.label :areas, "会場エリア設定（カンマ区切りで入力）", class: "form-label" %>
          <%= f.text_area :areas, class: "form-control", rows: 2, placeholder: "プロムナード, HIROPPA, 芝生エリア" %>
          <small class="text-muted">※ここで入力した名称が、出店登録時のプルダウンに表示されます。</small>
        </div>

        <hr class="my-4">

        <h5 class="mb-3">🅿️ 駐車場・インフラ管理情報</h5>
        <div class="col-12">
          <%= f.label :parking_info, "駐車場運用メモ", class: "form-label" %>
          <%= f.text_area :parking_info, class: "form-control", rows: 3, placeholder: "例：第1駐車場は運営専用20台確保。出店者は予約システムより事前予約必須。" %>
        </div>
        <div class="col-12">
          <%= f.label :parking_map_url, "駐車場マップURL", class: "form-label" %>
          <%= f.text_field :parking_map_url, class: "form-control", placeholder: "https://maps.app.goo.gl/..." %>
        </div>

        <div class="col-md-4">
          <%= f.label :total_inventory_desks, "長机 総在庫", class: "form-label" %>
          <%= f.number_field :total_inventory_desks, class: "form-control" %>
        </div>

        <div class="col-md-4">
          <%= f.label :total_inventory_round_tables, "丸テーブル 総在庫", class: "form-label" %>
          <%= f.number_field :total_inventory_round_tables, class: "form-control" %>
        </div>

        <div class="col-md-4">
          <%= f.label :total_inventory_chairs, "椅子 総在庫", class: "form-label" %>
          <%= f.number_field :total_inventory_chairs, class: "form-control" %>
        </div>
        
      </div>

      <div class="mt-5 d-flex justify-content-between">
        <%= link_to '戻る', shops_path, class: "btn btn-outline-secondary" %>
        <%= f.submit "イベント情報を保存する", class: "btn btn-primary btn-lg" %>
      </div>
    </div>
  </div>
<% end %>
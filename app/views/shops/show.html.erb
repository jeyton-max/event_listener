<% # app/views/shops/show.html.erb %>
<div class="container" style="max-width: 900px; margin: 40px auto; font-family: sans-serif;">
  
  <%# --- ヘッダーエリア --- %>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid #333; padding-bottom: 10px;">
    <h1 style="margin: 0;"><%= @shop.name %> <small style="color: #666; font-size: 1.1rem;">（<%= @shop.category %>）</small></h1>
    <div>
      <%= link_to '編集する', edit_shop_path(@shop), class: "btn btn-warning" %>
      <%= link_to '一覧に戻る', shops_path, class: "btn btn-secondary", style: "margin-left: 10px;" %>
    </div>
  </div>

  <div style="display: flex; gap: 30px; margin-bottom: 30px; flex-wrap: wrap;">
    <%# --- 左側：画像表示エリア --- %>
    <div style="flex: 1; min-width: 300px; text-align: center; border: 1px solid #ddd; padding: 15px; border-radius: 10px; background: #fafafa;">
      <% if @shop.layout_image.attached? %>
        <%= image_tag @shop.layout_image, style: "width: 100%; height: auto; border-radius: 5px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);" %>
      <% else %>
        <div style="width: 100%; height: 200px; background: #eee; display: flex; align-items: center; justify-content: center; color: #999; border-radius: 5px;">画像未設定</div>
      <% end %>
    </div>

    <%# --- 右側：基本出店情報・料金エリア --- %>
    <div style="flex: 1.5; min-width: 300px;">
      <h3 style="margin-top: 0; border-bottom: 1px solid #eee;">基本出店情報</h3>
      <table style="width: 100%; border-collapse: collapse;">
        <tr>
          <th style="padding: 10px; text-align: left; width: 130px;">希望ブース数</th>
          <td style="padding: 10px;"><%= @shop.booth_count %> ブース</td>
        </tr>
        <tr>
          <th style="padding: 10px; text-align: left;">出店エリア</th>
          <td style="padding: 10px;"><span style="background: #2c3e50; color: white; padding: 4px 12px; border-radius: 4px; font-weight: bold;"><%= @shop.area.presence || "未定" %></span></td>
        </tr>
      </table>

      <%# 💰 料金計算（既存機能維持） %>
      <div style="margin-top: 20px; padding: 15px; background: #fdfdfd; border: 1px solid #eee; border-left: 5px solid #2c3e50; border-radius: 4px;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 5px; font-size: 0.9rem;">
          <span>出店料合計:</span>
          <span><%= number_to_currency(@shop.total_booth_fee, unit: "¥", precision: 0) %></span>
        </div>
        <div style="display: flex; justify-content: space-between; margin-bottom: 5px; font-size: 0.9rem;">
          <span>備品・電力合計:</span>
          <span><%= number_to_currency(@shop.total_equipment_fee, unit: "¥", precision: 0) %></span>
        </div>
        <div style="display: flex; justify-content: space-between; font-size: 1.3rem; font-weight: bold; color: #d90429; margin-top: 5px; border-top: 1px solid #eee; padding-top: 5px;">
          <span>請求総額:</span>
          <span><%= number_to_currency(@shop.grand_total, unit: "¥", precision: 0) %></span>
        </div>
      </div>

      <%# 📸 Instagramスクショ機能（既存機能維持） %>
      <% if @shop.instagram_url.present? && @shop.instagram_url != "https://" %>
        <details style="margin-top: 15px; border: 1px solid #e1306c; border-radius: 8px; overflow: hidden; background: #fff;">
          <summary style="background: #fff0f5; color: #e1306c; padding: 10px; cursor: pointer; font-weight: bold; list-style: none; text-align: center;">
            📸 スクショ用：Instagram投稿を表示
          </summary>
          <div style="padding: 20px; text-align: center; border-top: 1px solid #ffd1dc;">
             <%= instagram_embed_tag(@shop.instagram_url) %>
          </div>
        </details>
      <% end %>
    </div>
  </div>

  <%# --- 🚒 安全管理・火器利用（NEW） --- %>
  <% if @shop.has_fire %>
    <div style="background: #fff5f5; padding: 20px; border-radius: 10px; margin-bottom: 30px; border: 1px solid #feb2b2; display: flex; align-items: center; gap: 20px;">
      <div style="font-size: 2.5rem;">🚒</div>
      <div style="flex: 1;">
        <h3 style="margin: 0 0 5px 0; color: #c53030; font-size: 1.1rem; font-weight: bold;">安全管理・火器利用</h3>
        <p style="margin: 0;">
          使用火器: <strong style="font-size: 1.2rem;"><%= @shop.fire_type.presence || "（種類未入力）" %></strong>
          <span style="margin-left: 15px; background: <%= @shop.has_extinguisher ? '#c53030' : '#718096' %>; color: white; padding: 2px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: bold;">
            <%= @shop.has_extinguisher ? "🔥 消火器持込確認済" : "⚠ 消火器未確認" %>
          </span>
        </p>
      </div>
    </div>
  <% end %>

  <%# --- 🚚 荷物配送管理情報（NEW） --- %>
  <% if @shop.delivery_needed %>
    <div style="background: #f0fdf4; padding: 25px; border-radius: 10px; margin-bottom: 30px; border: 1px solid #bbf7d0; display: flex; align-items: flex-start; gap: 20px;">
      <div style="font-size: 2.5rem;">🚚</div>
      <div style="flex: 1;">
        <h3 style="margin-top: 0; color: #166534; border-bottom: 1px solid #bbf7d0; padding-bottom: 5px; font-weight: bold;">荷物配送管理情報</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 10px;">
          <div>
            <strong style="color: #555; font-size: 0.85rem;">現在の配送状況:</strong><br>
            <span style="display: inline-block; margin-top: 5px; padding: 4px 12px; border-radius: 20px; font-weight: bold; background: #fff; border: 2px solid #166534; color: #166534;">
              <%= @shop.delivery_status_i18n rescue @shop.delivery_status %>
            </span>
          </div>
          <div>
            <strong style="color: #555; font-size: 0.85rem;">予定口数:</strong><br>
            <span style="font-size: 1.2rem; font-weight: bold;"><%= @shop.delivery_count || 0 %> 個</span>
          </div>
          <div style="grid-column: span 2;">
            <strong style="color: #555; font-size: 0.85rem;">荷物伝票番号:</strong><br>
            <span style="font-size: 1.1rem; font-family: monospace; background: #fff; padding: 4px 12px; border-radius: 4px; border: 1px solid #bbf7d0; display: block; margin-top: 5px;">
              <%= @shop.delivery_tracking_number.presence || "（未登録）" %>
            </span>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# --- 📍 発送・連絡先情報 --- %>
  <div style="background: #eef7ff; padding: 25px; border-radius: 10px; margin-bottom: 30px; border: 1px solid #cce5ff;">
    <h3 style="margin-top: 0; color: #004085; border-bottom: 1px solid #b8daff; padding-bottom: 5px; font-weight: bold;">📍 発送・連絡先情報</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 15px;">
      <div>
        <p style="margin-bottom: 15px;">
          <strong style="color: #555;">代表者名（配送先宛名）:</strong><br>
          <span style="font-size: 1.1rem; font-weight: bold;"><%= @shop.shipping_name.presence || "（未回答）" %> 様</span>
        </p>
        <p>
          <strong style="color: #555;">当日連絡先電話番号:</strong><br>
          <% if @shop.tel.present? %>
            <%= link_to @shop.tel, "tel:#{@shop.tel.gsub(/-/, '')}", style: "font-size: 1.1rem; color: #007bff; text-decoration: none; font-weight: bold;" %>
          <% else %>
            （未回答）
          <% end %>
        </p>
      </div>
      <div>
        <p>
          <strong style="color: #555;">領収書宛名:</strong><br>
          <span style="font-size: 1.1rem;"><%= @shop.receipt_name.presence || "（ショップ名と同じ）" %></span>
        </p>
        <p style="margin-top: 15px;">
          <strong style="color: #555;">配送先住所:</strong><br>
          <span style="font-size: 1.1rem;"><%= @shop.address.presence || "（未回答）" %></span>
        </p>
      </div>
    </div>
  </div>

  <%# --- 🗓️ 日別備品・電力内訳 --- %>
  <h3 style="border-left: 5px solid #2c3e50; padding-left: 10px; margin-bottom: 15px; font-weight: bold;">🗓️ 日別備品・電力内訳</h3>
  <table style="width: 100%; border-collapse: collapse; text-align: center; background: white; border: 1px solid #ddd;">
    <thead>
      <tr style="background: #2c3e50; color: white;">
        <th style="padding: 12px;">日付</th>
        <th>長机</th>
        <th>丸テーブル</th>
        <th>椅子</th>
        <th>電力</th>
      </tr>
    </thead>
    <tbody>
      <% if @shop.daily_details.any? %>
        <% @shop.daily_details.order(:event_date).each do |detail| %>
          <tr style="border-bottom: 1px solid #eee;">
            <td style="padding: 12px; font-weight: bold;">
              <%= detail.event_date.strftime("%m/%d") %>（<%= %w(日 月 火 水 木 金 土)[detail.event_date.wday] %>）
            </td>
            <td><%= detail.desk_count || 0 %> 台</td>
            <td><%= detail.round_table_count || 0 %> 台</td>
            <td><%= detail.chair_count || 0 %> 脚</td>
            <td>
              <% if detail.is_electric_needed %>
                <span style="color: #f72585; font-weight: bold; background: #ffe5f0; padding: 4px 12px; border-radius: 10px; font-size: 0.85rem;">利用あり</span>
              <% else %>
                <span style="color: #ccc;">ー</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="5" style="padding: 30px; color: #999;">日別詳細データがありません</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
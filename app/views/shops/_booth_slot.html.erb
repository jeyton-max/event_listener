<div class="booth-target" 
     data-layout-target="booth"
     data-booth-id="<%= booth_id %>"
     data-action="dragover->layout#dragover dragenter->layout#dragenter dragleave->layout#dragleave drop->layout#drop"
     style="width: 120px; height: 80px; border: 2px dashed #cbd5e0; border-radius: 8px; background: #f8fafc; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: all 0.2s; position: relative; cursor: default;">
  <span style="font-weight: bold; color: #cbd5e0; font-size: 0.75rem;"><%= booth_id %></span>
</div>